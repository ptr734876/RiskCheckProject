# Скопируйте этот файл в .env и заполните значения.

# --- Ключи Яндекс.Карт -------------------------------------------
# Получить: https://developer.tech.yandex.ru/services/
#
# Нужны ДВА РАЗНЫХ ключа — это частая ошибка:
#
# 1) Geocoder API — поиск адреса на бэкенде (превращает
#    "ул. Садовая, 14" в координаты).
YANDEX_GEOCODER_KEY=

# 2) JavaScript API и HTTP Геокодер — отрисовка карты в браузере.
#    Отдаётся фронтенду через /api/map/config.
YANDEX_JS_API_KEY=

# --- Парсер Росреестра --------------------------------------------
# Отдельный сервис (frontend/src/utils/parser), даёт юридические
# данные для карточки на Шаге 1. Работать без него можно —
# карта и окружение от него не зависят.
ROSREESTR_PARSER_URL=http://127.0.0.1:8000

# Парсер поднимает браузер и ходит на внешний сайт — это долго.
ROSREESTR_PARSER_TIMEOUT=60

# Поставьте 0, чтобы не обращаться к парсеру вовсе.
ROSREESTR_PARSER_ENABLED=1

# Автозапуск: бэкенд сам поднимает парсер при старте и гасит
# при выходе. Поставьте 0, если хотите запускать его вручную
# отдельной командой (например, чтобы видеть его логи).
ROSREESTR_PARSER_AUTOSTART=1

# Сколько ждать готовности парсера при автозапуске, с.
# Playwright поднимает Chromium — обычно 5-15 секунд.
ROSREESTR_PARSER_BOOT_TIMEOUT=45

# Путь к папке парсера. По умолчанию вычисляется относительно
# проекта, менять нужно только при нестандартном размещении.
# ROSREESTR_PARSER_DIR=/path/to/frontend/src/utils/parser

# --- Прочее -------------------------------------------------------
# Радиус поиска объектов окружения, метры.
# В плотной городской застройке 3000 может приводить к таймаутам
# OpenStreetMap — тогда уменьшите до 1500.
GEO_SEARCH_RADIUS=3000

SECRET_KEY=dev-secret-change-me
DATABASE_URL=sqlite:///atlas.db
