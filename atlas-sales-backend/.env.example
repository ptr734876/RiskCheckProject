# Скопируйте этот файл в .env и заполните значения.

# --- Ключи Яндекс.Карт -------------------------------------------
# Получить: https://developer.tech.yandex.ru/services/
#
# Нужны ДВА РАЗНЫХ ключа — это частая ошибка:
#
# 1) Geocoder API — поиск адреса на бэкенде (превращает
#    "ул. Садовая, 14" в координаты).
YANDEX_GEOCODER_KEY=

# 2) JavaScript API и HTTP Геокодер — отрисовка карты в браузере.
#    Отдаётся фронтенду через /api/map/config.
YANDEX_JS_API_KEY=

# --- Парсер Росреестра (atlas-sales-backend/rosreestr-parser/) ------------------------
# Юридические данные для Шага 1. Без него сайт работает —
# карта и окружение не зависят от парсера.
ROSREESTR_PARSER_URL=http://127.0.0.1:8000
ROSREESTR_PARSER_TIMEOUT=60
ROSREESTR_PARSER_ENABLED=1
ROSREESTR_PARSER_AUTOSTART=1
ROSREESTR_PARSER_BOOT_TIMEOUT=45
# ROSREESTR_PARSER_DIR=/path/to/atlas-sales-backend/rosreestr-parser

# --- Прочее -------------------------------------------------------
# Радиус поиска объектов окружения, метры.
# В плотной городской застройке 3000 может приводить к таймаутам
# OpenStreetMap — тогда уменьшите до 1500.
GEO_SEARCH_RADIUS=3000

SECRET_KEY=dev-secret-change-me
DATABASE_URL=sqlite:///atlas.db
